#WAP to print character pyramid.
def symmetrical_pyramid(rows):
    for i in range(1,rows+1):
        print(" " * (rows - i), end = "") #1 Print leading spaces
        for j in range(1, i+1):
            print(chr(64 + j), end ="") #2 Print increasing sequence of letters.
        for j in range(i - 1,0,-1):
            print(chr(64 + j), end = "") #3 Print decreasing sequence of letters.
        print() #Move to the next line.

#Generate a 5-row pyramid
symmetrical_pyramid(5)